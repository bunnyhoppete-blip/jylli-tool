{
  "name": "jylli-tool",
  "version": "1.4.1",
  "description": "Professional Windows Optimization Tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.jylli.tool",
    "productName": "Jylli Tool",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName} Setup.exe",
      "installerSidebar": "assets/installer-sidebar.bmp",
      "uninstallerSidebar": "assets/installer-sidebar.bmp",
      "installerHeader": "assets/installer-header.bmp"
    },
    "asarUnpack": [
      "assets/lhm/**",
      "assets/fancontrol/**",
      "assets/cpuz/**",
      "assets/ryzenadj/**",
      "assets/scewin/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "Jyllipete",
      "repo": "jylli-tool",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "discord-rpc": "^4.0.1",
    "discord.js": "^14.26.4",
    "electron-updater": "^6.8.3"
  }
}
